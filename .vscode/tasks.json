{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "Start MLflow Server",
      "type": "shell",
      "command": "uv run mlflow server --host 0.0.0.0 --port 5000 --backend-store-uri sqlite:///data/mlflow/db/mlflow.db --default-artifact-root data/mlflow/artifacts --serve-artifacts",
      "problemMatcher": [],
      "isBackground": true,
      "presentation": {
        "reveal": "always",
        "panel": "dedicated",
        "showReuseMessage": false
      }
    },
    {
      "label": "Start Marimo with MCP",
      "type": "shell",
      "command": "uv run marimo edit examples/ --mcp --no-token --port 2718",
      "problemMatcher": [],
      "isBackground": true,
      "presentation": {
        "reveal": "always",
        "panel": "dedicated",
        "showReuseMessage": false
      }
    },
    {
      "label": "Start MLflow MCP Server",
      "type": "shell",
      "command": "uv run mlflow mcp run",
      "options": {
        "env": {
          "MLFLOW_TRACKING_URI": "http://localhost:5000"
        }
      },
      "problemMatcher": [],
      "isBackground": true,
      "presentation": {
        "reveal": "always",
        "panel": "dedicated",
        "showReuseMessage": false
      }
    },
    {
      "label": "Run Tests",
      "type": "shell",
      "command": "uv run pytest",
      "problemMatcher": [],
      "presentation": {
        "reveal": "always",
        "panel": "shared"
      },
      "group": {
        "kind": "test",
        "isDefault": true
      }
    },
    {
      "label": "Run Tests with Coverage",
      "type": "shell",
      "command": "uv run pytest --cov=src tests/",
      "problemMatcher": [],
      "presentation": {
        "reveal": "always",
        "panel": "shared"
      },
      "group": "test"
    },
    {
      "label": "Format & Lint with Ruff",
      "type": "shell",
      "command": "uv run ruff format . && uv run ruff check --fix .",
      "problemMatcher": [],
      "presentation": {
        "reveal": "always",
        "panel": "shared"
      }
    }
  ]
}
