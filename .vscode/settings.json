{
  // === Editor Settings ===
  "editor.formatOnSave": true,
  "editor.formatOnPaste": false,
  "editor.tabSize": 4,
  "editor.insertSpaces": true,
  "editor.rulers": [
    79,
    88
  ],
  // === Language-Specific Formatters ===
  "[python]": {
    "editor.defaultFormatter": "ms-python.black-formatter",
    "editor.formatOnSave": true,
    "editor.codeActionsOnSave": {
      "source.organizeImports": "explicit"
    }
  },
  "[typescript]": {
    "editor.defaultFormatter": "biomejs.biome"
  },
  "[typescriptreact]": {
    "editor.defaultFormatter": "biomejs.biome"
  },
  // === Marimo Extension Settings ===
  "marimo.disableManagedLanguageFeatures": false,
  "marimo.disableUvIntegration": false,
  "marimo.lsp.path": [
    "D:\\projects\\synapticore-io\\marimo-flow\\.venv\\Scripts\\uvx.exe",
    "marimo-lsp"
  ],
  "marimo.ruff.path": "D:\\projects\\synapticore-io\\marimo-flow\\.venv\\Scripts\\ruff.exe",
  "marimo.uv.path": "D:\\projects\\synapticore-io\\marimo-flow\\.venv\\Scripts\\uv.exe",
  // === Python Interpreter Settings ===
  "python.defaultInterpreterPath": "${workspaceFolder}/.venv/Scripts/python.exe",
  "python.terminal.activateEnvironment": true,
  // === Python Analysis Settings ===
  "python.analysis.typeCheckingMode": "basic",
  "python.analysis.autoImportCompletions": true,
  "python.analysis.diagnosticMode": "workspace",
  "python.analysis.extraPaths": [
    "${workspaceFolder}",
    "${workspaceFolder}/src",
    "${workspaceFolder}/snippets"
  ],
  "python.analysis.importFormat": "absolute",
  "python.analysis.autoSearchPaths": true,
  // === Black Formatter ===
  "black-formatter.args": [
    "--line-length=79"
  ],
  // === Ruff Linter ===
  "ruff.lint.args": [
    "--line-length=79"
  ],
  // === Python Testing ===
  "python.testing.pytestEnabled": true,
  "python.testing.unittestEnabled": false,
  "python.testing.pytestArgs": [
    "tests"
  ],
  // === Files ===
  "files.exclude": {
    "**/__pycache__": true,
    "**/*.pyc": true,
    "**/.pytest_cache": true,
    "**/.mypy_cache": true,
    "**/.ruff_cache": true,
    "**/mlruns": true,
    "**/.marimo": true
  },
  "files.watcherExclude": {
    "**/.git/objects/**": true,
    "**/.git/subtree-cache/**": true,
    "**/node_modules/**": true,
    "**/.venv/**": true,
    "**/data/mlflow/**": true
  },
  // === Search Settings ===
  "search.exclude": {
    "**/node_modules": true,
    "**/bower_components": true,
    "**/.venv": true,
    "**/data/mlflow": true,
    "**/__pycache__": true,
    "**/.pytest_cache": true
  },
  // === Terminal ===
  "terminal.integrated.env.windows": {
    "MLFLOW_TRACKING_URI": "http://localhost:5000",
    "PYTHONPATH": "${workspaceFolder};${workspaceFolder}/src"
  },
  // === Tasks (for running MLflow, Marimo, etc.) ===
  "tasks.autoDetect": "on",
  "cursorpyright.analysis.autoImportCompletions": true,
  "cursorpyright.analysis.autoSearchPaths": true,
  "cursorpyright.analysis.diagnosticMode": "workspace",
  "cursorpyright.analysis.extraPaths": [
    "${workspaceFolder}",
    "${workspaceFolder}/src",
    "${workspaceFolder}/snippets"
  ],
  "cursorpyright.analysis.typeCheckingMode": "basic"
}