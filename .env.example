# Copy to `.env` (gitignored) and fill the ones you actually use.
# Real shell-exported env vars always win over this file.

# ── Ollama (local daemon or Ollama Cloud via local daemon) ──────────────
OLLAMA_BASE_URL=http://localhost:11434/v1
# OLLAMA_API_KEY=          # only needed for hosted Ollama endpoints

# ── Cloud providers (fill what you use) ─────────────────────────────────
# OPENAI_API_KEY=sk-...
# ANTHROPIC_API_KEY=sk-ant-...
# GROQ_API_KEY=gsk_...
# MISTRAL_API_KEY=
# TOGETHER_API_KEY=
# FIREWORKS_API_KEY=
# OPENROUTER_API_KEY=
# DEEPSEEK_API_KEY=
# CEREBRAS_API_KEY=
# XAI_API_KEY=
# GOOGLE_API_KEY=          # google-gla
# HF_TOKEN=                # huggingface

# ── MLflow / marimo (optional — override defaults here or in config.yaml) ─
# MLFLOW_TRACKING_URI=sqlite:///mlruns.db
# MARIMO_MCP_URL=http://127.0.0.1:2718/mcp/server

# ── Quick per-role model overrides (wins over config.yaml) ──────────────
# MARIMO_FLOW_MODEL_LEAD=anthropic:claude-sonnet-4-6
# MARIMO_FLOW_MODEL_ROUTE=groq:llama-3.3-70b-versatile
